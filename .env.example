# Google Cloud Storage Configuration
# These environment variables configure GCS upload for dataset zip files

# Name of the GCS bucket to upload to
GCS_BUCKET_NAME=bucket-name

# GCP project ID
GCS_PROJECT_ID=project-id

# Bucket location (currently unused, kept for compatibility)
GCS_BUCKET_LOCATION=bucket-location

# Base directory in the bucket (zip files will be uploaded to: {GCS_BUCKET_DIRECTORY}/import_tmp/)
GCS_BUCKET_DIRECTORY=data

# Storage Emulator Host (optional - for local development/testing)
# When set, the application will use a local GCS emulator instead of connecting to real GCS
# Example: http://localhost:4443
# STORAGE_EMULATOR_HOST=http://localhost:4443

# Callback Configuration
# URL to call after successful GCS upload
# The service will POST a JSON payload with {"hash": "<request_hash>", "fileName": "<zip_filename>"}
CALLBACK_URL=https://syntetiq.docker.localhost/api/omniverse/callback

# Skip SSL certificate verification for callback (for local development)
# Set to "false" to skip SSL verification (not recommended for production)
CALLBACK_VERIFY_SSL=true

CONDA_ENV_PATH=C:\Users\user\Miniconda3\envs\env_isaacsim